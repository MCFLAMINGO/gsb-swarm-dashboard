{
  "crons": [
    {
      "path": "/api/cron/heartbeat",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/inbox-watcher",
      "schedule": "0 */6 * * *"
    }
  ],
  "functions": {
    "src/app/api/dispatch/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/jobs/[jobId]/route.ts": {
      "maxDuration": 30
    }
  }
}
